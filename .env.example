# ── Copy to .env (never commit .env) ──────────────────────────────────────────
# Core datastores
DATABASE_URL=postgresql://credresearch:devpass@postgres:5432/credresearch
REDIS_URL=redis://redis:6379/0

# Auth (RS256). Generate keys: see GETTING_STARTED.md §4
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Shared secret signing the internal backend -> ai-worker JWT (audience: ai-worker)
INTERNAL_SERVICE_SECRET=change-me-dev-secret

# Object storage (MinIO locally; R2/Spaces/S3 in prod)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=credresearch
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio12345
STORAGE_REGION=us-east-1

# LLM gateway (provider-agnostic). Default to latest Claude models.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
LLM_MODEL_STRONG=claude-opus-4-8
EMBEDDING_MODEL=
EMBEDDING_DIM=1536

# PDF conversion
GOTENBERG_URL=http://gotenberg:3000

# Payments (sandbox keys for dev)
PAYSTACK_SECRET=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET=
FLUTTERWAVE_WEBHOOK_HASH=

# Email (MailHog locally: host=mailhog port=1025)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_FROM=no-reply@credresearch.local

# SMS / WhatsApp (optional)
SMS_PROVIDER=
TERMII_API_KEY=
WHATSAPP_TOKEN=

# Observability
SENTRY_DSN=

# Public URLs (links, magic-links)
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

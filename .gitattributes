# Normalize line endings: store LF in the repo, check out native on each OS.
* text=auto eol=lf

# Scripts that must stay LF even on Windows checkouts.
*.sh   text eol=lf

# Windows-only scripts stay CRLF.
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Treat these as binary (no EOL munging, no diff noise).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.jar  binary
*.woff binary
*.woff2 binary
